generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  STAFF
  ADMIN
  SUPER_ADMIN
}

enum ItemStatus {
  ACTIVE
  RELEASED
}

enum AuditItemStatus {
  FOUND
  MISSING
  UNKNOWN
}

enum ScanType {
  AUDIT
  CREATE
  VERIFY
}

enum AuditType {
  STANDARD
  INITIAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  releases        Release[]
  audits          Audit[]
  barcodeLogs     BarcodeLog[]
  itemCorrections ItemCorrection[]
  activityLogs    ActivityLog[]
  itemEditLogs    ItemEditLog[]

  @@map("users")
}

model Branch {
  id        String           @id @default(cuid())
  name      String           @unique
  customers CustomerBranch[]
  createdAt DateTime         @default(now())

  @@map("branches")
}

model CustomerBranch {
  customerId String
  branchId   String
  customer   Customer @relation(fields: [customerId], references: [id])
  branch     Branch   @relation(fields: [branchId], references: [id])

  @@id([customerId, branchId])
  @@map("customer_branches")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  nic       String   @unique
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    Item[]
  branches CustomerBranch[]

  @@index([nic])
  @@map("customers")
}

model Item {
  id          String     @id @default(cuid())
  barcode     String     @unique
  customerId  String
  itemType    String
  weight      Decimal    @db.Decimal(8, 3)   // net weight
  grossWeight Decimal?   @db.Decimal(8, 3)
  karatage    Int?
  ticketNo    String?
  remarks     String?
  description String?
  pawnDate    DateTime
  status      ItemStatus @default(ACTIVE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  customer        Customer         @relation(fields: [customerId], references: [id])
  release         Release?
  auditItems      AuditItem[]
  barcodeLogs     BarcodeLog[]
  itemCorrections ItemCorrection[]
  editLogs        ItemEditLog[]

  @@index([barcode])
  @@index([customerId])
  @@index([status])
  @@index([customerId, status])
  @@index([ticketNo])
  @@map("items")
}

model ItemEditLog {
  id          String   @id @default(cuid())
  itemId      String
  editedById  String
  field       String
  oldValue    String
  newValue    String
  editedAt    DateTime @default(now())

  item      Item @relation(fields: [itemId], references: [id])
  editedBy  User @relation(fields: [editedById], references: [id])

  @@index([itemId])
  @@map("item_edit_logs")
}

model Release {
  id           String   @id @default(cuid())
  itemId       String   @unique
  releasedById String
  releaseDate  DateTime @default(now())
  notes        String?
  createdAt    DateTime @default(now())

  item       Item @relation(fields: [itemId], references: [id])
  releasedBy User @relation(fields: [releasedById], references: [id])

  @@index([releasedById])
  @@index([releaseDate])
  @@map("releases")
}

model Audit {
  id               String    @id @default(cuid())
  auditType        AuditType @default(STANDARD)
  createdAt        DateTime  @default(now())
  createdById      String
  totalItemsAtTime Int
  notes            String?
  finalizedAt      DateTime? // NULL = audit still in progress
  filterDateFrom   DateTime?
  filterDateTo     DateTime?
  filterBranchId   String?

  createdBy      User             @relation(fields: [createdById], references: [id])
  auditItems     AuditItem[]
  itemCorrections ItemCorrection[]

  @@map("audits")
}

model AuditItem {
  id      String          @id @default(cuid())
  auditId String
  barcode String
  status  AuditItemStatus
  itemId  String?
  remarks String?

  audit       Audit            @relation(fields: [auditId], references: [id])
  item        Item?            @relation(fields: [itemId], references: [id])
  corrections ItemCorrection[]

  @@unique([auditId, barcode]) // prevent duplicate scans in same audit
  @@index([auditId])
  @@index([barcode])
  @@index([itemId])
  @@index([auditId, status])
  @@map("audit_items")
}

model ItemCorrection {
  id            String   @id @default(cuid())
  itemId        String
  auditId       String
  auditItemId   String
  field         String   // "weight" | "itemType" | "description"
  oldValue      String
  newValue      String
  correctedById String
  correctedAt   DateTime @default(now())

  item        Item      @relation(fields: [itemId], references: [id])
  audit       Audit     @relation(fields: [auditId], references: [id])
  auditItem   AuditItem @relation(fields: [auditItemId], references: [id])
  correctedBy User      @relation(fields: [correctedById], references: [id])

  @@index([itemId])
  @@index([auditId])
  @@index([auditItemId])
  @@map("item_corrections")
}

model BarcodeLog {
  id          String   @id @default(cuid())
  itemId      String
  scannedById String?
  scannedAt   DateTime @default(now())
  scanType    ScanType

  item      Item  @relation(fields: [itemId], references: [id])
  scannedBy User? @relation(fields: [scannedById], references: [id])

  @@index([itemId])
  @@index([scanType])
  @@index([scannedAt])
  @@map("barcode_logs")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}
